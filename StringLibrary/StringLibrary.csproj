    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>StringLibrary.UppercaseCheck</PackageId>
    <Version>1.0.0</Version>
